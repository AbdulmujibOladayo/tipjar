# Stellar network: testnet | public
STELLAR_NETWORK=testnet

# Anchor handling fiat on-ramp (SEP-24)
ANCHOR_DOMAIN=testanchor.stellar.org

# Default creator wallet shown on the demo page
CREATOR_PUBKEY=

# Include fan messages as on-chain memos
MEMO_ENABLED=true

# Widget theme: light | dark | auto
WIDGET_THEME=auto
